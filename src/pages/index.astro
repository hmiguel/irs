---
import taxData from '../data/tax-data.json';
import inflationData from '../data/inflation.json';
import '../styles/main.css';

const INFLATION_MAP = Object.fromEntries(
  inflationData.map(({ year, inflation }) => [year, inflation])
);
---

<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Simulador IRS Portugal 2008–2026 · Calcula o teu IRS</title>
  <meta name="description" content="Simula o teu IRS em Portugal de 2008 a 2026. Calcula rendimento líquido, taxa efetiva de tributação e benefício municipal para qualquer município. Grátis e sem registo.">
  <meta name="keywords" content="simulador IRS, IRS Portugal, calculadoular IRS, taxa efetiva IRS, rendimento líquido, IRS 2024, IRS 2025, IRS 2026, declaração IRS">
  <meta name="author" content="Hugo Conceição">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://irs.lixo.dev/">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/jetbrains-mono.woff2">
  <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/plus-jakarta-sans.woff2">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://irs.lixo.dev/">
  <meta property="og:title" content="Simulador IRS Portugal 2008–2026">
  <meta property="og:description" content="Calcula o teu IRS em Portugal de 2008 a 2026 — rendimento líquido, taxa efetiva e benefício municipal por município.">
  <meta property="og:locale" content="pt_PT">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Simulador IRS Portugal 2008–2026">
  <meta name="twitter:description" content="Calcula o teu IRS em Portugal de 2008 a 2026 — rendimento líquido, taxa efetiva e benefício municipal por município.">

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Simulador IRS Portugal",
    "description": "Calculadora interativa do IRS em Portugal para os anos fiscais de 2008 a 2026. Calcula rendimento líquido, taxa efetiva de tributação e benefício municipal.",
    "url": "https://irs.lixo.dev/",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "inLanguage": "pt-PT",
    "isAccessibleForFree": true,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
    "author": { "@type": "Person", "name": "Hugo Conceição" },
    "about": {
      "@type": "Thing",
      "name": "Imposto sobre o Rendimento das Pessoas Singulares",
      "alternateName": "IRS",
      "description": "Imposto sobre rendimentos em Portugal, gerido pela Autoridade Tributária e Aduaneira"
    }
  })}></script>

  <script defer src="/js/alpinejs.min.js"></script>
</head>
<body x-data="irsCalc()" :class="darkMode ? '' : 'light'">
<div class="page" x-cloak>

  <!-- Year slider bar -->
  <nav class="year-bar" aria-label="Selecionar ano fiscal">
    <div class="year-bar-inline">
      <span class="year-bar-label" id="label-year-slider">Ano fiscal</span>
      <div class="year-bar-track">
        <div class="slider-wrap" style="margin-top:0;">
          <div class="slider-bubble" aria-hidden="true"
               :style="'left:clamp(16px,' + yearSliderPercent + '%,calc(100% - 16px))'"
               x-text="year">
          </div>
          <input type="range" id="input-year-slider" class="rng"
                 min="0" max="18" step="1"
                 aria-labelledby="label-year-slider"
                 :aria-valuetext="year + ' — Ano fiscal'"
                 x-model.number="yearIdx"
                 :style="'--pct:' + yearSliderPercent + '%'">
        </div>
        <div class="slider-ticks">
          <span>2008</span><span>2010</span><span>2012</span><span>2014</span>
          <span>2016</span><span>2018</span><span>2020</span><span>2022</span>
          <span>2024</span><span>2026</span>
        </div>
      </div>
    </div>
    <template x-if="prevYear">
      <span class="delta-context" x-text="'Δ vs ' + prevYear"></span>
    </template>
  </nav>

  <!-- Heading -->
  <div class="heading">
    <h1>Simulador IRS</h1>
    <button class="theme-toggle" @click="toggleTheme()"
            :aria-label="darkMode ? 'Mudar para modo claro' : 'Mudar para modo escuro'">
      <template x-if="darkMode">
        <svg aria-hidden="true" focusable="false" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <path stroke-linecap="round" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </template>
      <template x-if="!darkMode">
        <svg aria-hidden="true" focusable="false" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </template>
    </button>
  </div>

  <!-- Two-column grid -->
  <div class="main-grid">

    <!-- ── LEFT: Inputs ── -->
    <div style="display:flex; flex-direction:column; gap:1.25rem;">

      <!-- Income slider -->
      <div class="card">
        <div class="card-body-sm">
          <div class="slider-header">
            <label class="card-label" for="input-gross-slider">Rendimento Bruto</label>
            <span class="slider-big-val" aria-hidden="true" x-text="'€ ' + fmt(gross)"></span>
          </div>
          <div class="slider-wrap">
            <div class="slider-bubble" aria-hidden="true"
                 :style="'left:clamp(16px,' + sliderPercent + '%,calc(100% - 16px))'"
                 x-text="'€ ' + fmt(gross)">
            </div>
            <input type="range" id="input-gross-slider" class="rng"
                   min="0" max="100000" step="500"
                   :aria-valuetext="'€ ' + fmt(gross)"
                   x-model="grossInput"
                   :style="'--pct:' + sliderPercent + '%'">
          </div>
          <div class="slider-ticks">
            <span>0</span><span>25k</span><span>50k</span><span>75k</span><span>100k</span>
          </div>
        </div>
      </div>

      <!-- Fields -->
      <div class="card">
        <div class="card-header"><div class="card-label">Dados</div></div>
        <div class="card-body">

          <div class="field">
            <label for="input-gross">Rendimento Bruto Anual (€)</label>
            <input id="input-gross" type="number" min="0" step="100" placeholder="Ex: 35 000"
                   x-model="grossInput">
          </div>

          <div class="field-row">
            <div class="field" style="margin-bottom:0;">
              <label for="input-municipality">Município</label>
              <select id="input-municipality" x-model="municipality">
                <template x-for="m in sortedMunicipalities" :key="m">
                  <option :value="m" x-text="titleCase(m)"></option>
                </template>
              </select>
            </div>
            <div class="field" style="margin-bottom:0;">
              <label for="input-year" id="label-year">Ano fiscal</label>
              <div id="input-year" class="year-badge" role="status" aria-live="polite" x-text="year"></div>
            </div>
          </div>

          <div style="height:.75rem;"></div>

          <div class="field">
            <label for="input-specific-deduction">Dedução específica (€)
              <span class="badge badge-auto" x-show="!specificDeductionInput">calculado</span>
            </label>
            <input id="input-specific-deduction" type="number" min="0" step="0.01"
                   :placeholder="gross > 0 ? fmt(specificDeductionAuto) : 'Ex: 4 350,24'"
                   x-model="specificDeductionInput">
          </div>

          <div class="field-row">
            <div class="field" style="margin-bottom:0;">
              <label for="input-deductions">Deduções à coleta</label>
              <input id="input-deductions" type="number" min="0" step="10" placeholder="Ex: 892"
                     aria-describedby="hint-deductions"
                     x-model="deductionsInput">
              <div id="hint-deductions" class="optional-label">opcional</div>
            </div>
            <div class="field" style="margin-bottom:0;">
              <label for="input-withheld">Retenção na fonte</label>
              <input id="input-withheld" type="number" min="0" step="10" placeholder="Ex: 5 200"
                     aria-describedby="hint-withheld"
                     x-model="withheldInput">
              <div id="hint-withheld" class="optional-label">opcional</div>
            </div>
          </div>

        </div>
      </div>

    </div><!-- /LEFT -->

    <!-- ── RIGHT: Results ── -->
    <div class="card">

      <!-- Empty state -->
      <template x-if="gross === 0">
        <div class="results-empty">
          <svg aria-hidden="true" focusable="false" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          <span>Introduza o rendimento bruto para ver a simulação</span>
        </div>
      </template>

      <!-- Results -->
      <template x-if="gross > 0">
        <div aria-live="polite" aria-atomic="true" aria-label="Resultados da simulação">

          <!-- Hero -->
          <div class="hero">
            <div class="hero-label">Rendimento Líquido estimado</div>
            <div class="hero-amount">
              <span x-text="'€ ' + fmt(takeHome)"></span>
              <template x-if="deltaTakeHome !== null">
                <span :class="deltaClass(deltaTakeHome, false)">
                  <span class="sr-only" x-text="deltaTakeHome > 0 ? 'subiu' : 'desceu'"></span>
                  <span aria-hidden="true" x-text="(deltaTakeHome > 0 ? '+' : '−') + ' € ' + fmt(Math.abs(deltaTakeHome))"></span>
                </span>
              </template>
            </div>
            <div class="hero-sub" x-text="'de € ' + fmt(gross) + ' brutos · ' + year"></div>
          </div>

          <!-- Stat chips -->
          <div class="stat-chips">
            <div class="stat-chip chip-ss">
              <div class="stat-chip-label">Seg. Social</div>
              <div class="stat-chip-val" x-text="'€ ' + fmt(specificDeduction)"></div>
              <div class="stat-chip-pct" x-text="fmtPct(specificDeduction/gross*100)"></div>
            </div>
            <div class="stat-chip chip-tax">
              <div class="stat-chip-label">IRS Líquido</div>
              <div class="stat-chip-val" x-text="'€ ' + fmt(netTax)"></div>
              <div class="stat-chip-pct" x-text="fmtPct(netTax/gross*100)"></div>
            </div>
            <div class="stat-chip chip-net">
              <div class="stat-chip-label">Líquido</div>
              <div class="stat-chip-val" x-text="'€ ' + fmt(takeHome)"></div>
              <div class="stat-chip-pct" x-text="fmtPct(takeHome/gross*100)"></div>
            </div>
          </div>

          <!-- Breakdown bar -->
          <div class="breakdown-section">
            <div class="breakdown-bar">
              <div class="breakdown-seg seg-ss"  :style="'width:' + Math.max(1, specificDeduction/gross*100) + '%'"></div>
              <div class="breakdown-seg seg-tax" :style="'width:' + Math.max(0, netTax/gross*100) + '%'"></div>
              <div class="breakdown-seg seg-net" :style="'width:' + Math.max(0, takeHome/gross*100) + '%'"></div>
            </div>
            <div class="breakdown-legend">
              <div class="legend-item">
                <div class="legend-dot" style="background:var(--amber)"></div>
                <span>Seg. Social + Ded. Específica</span>
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background:var(--red)"></div>
                <span>IRS</span>
              </div>
              <div class="legend-item">
                <div class="legend-dot" style="background:var(--green)"></div>
                <span>Líquido</span>
              </div>
            </div>
          </div>

          <!-- Detail breakdown -->
          <div class="detail-section">

            <div class="detail-row sub">
              <span class="lbl">
                Dedução específica
                <span class="badge badge-auto" x-show="!specificDeductionInput">calculado</span>
              </span>
              <span class="val" x-text="'− € ' + fmt(specificDeduction)"></span>
            </div>

            <div class="detail-row strong">
              <span class="lbl">Rendimento Coletável</span>
              <span class="val" x-text="'€ ' + fmt(collectableIncome)"></span>
            </div>

            <div class="detail-row sub">
              <span class="lbl">
                Escalão
                <button class="badge badge-btn" @click="showBrackets = true; $nextTick(() => document.querySelector('.brackets-section')?.scrollIntoView({behavior:'smooth', block:'nearest'}))" :title="'Ver escalões ' + year" x-text="fmtPct(bracket.tax * 100)"></button>
              </span>
              <span class="val" x-text="'€ ' + fmt(amountCalculated)"></span>
            </div>

            <div class="detail-row sub">
              <span class="lbl">Parcela a abater</span>
              <span class="val" x-text="'− € ' + fmt(bracket.parcel)"></span>
            </div>

            <div class="detail-row">
              <span class="lbl">Coleta (base)</span>
              <span class="val" x-text="'€ ' + fmt(baseTax)"></span>
            </div>

            <template x-if="deductions > 0">
              <div class="detail-row sub">
                <span class="lbl">Deduções à coleta</span>
                <span class="val" x-text="'− € ' + fmt(deductions)"></span>
              </div>
            </template>

            <div class="detail-row sub">
              <span class="lbl">
                Benefício municipal
                <span class="badge" x-text="titleCase(municipality) + ' ' + fmtPct(countyRate*100)"></span>
              </span>
              <span class="val"
                    x-text="countyBenefit > 0 ? '− € ' + fmt(countyBenefit) : '€ ' + fmt(0)">
              </span>
            </div>

            <div class="detail-row strong">
              <span class="lbl">Coleta Líquida</span>
              <span class="val" style="display:flex;align-items:baseline;gap:.35rem;">
                <span x-text="'€ ' + fmt(netTax)"></span>
                <template x-if="deltaNetTax !== null">
                  <span :class="deltaClass(deltaNetTax, true)">
                    <span class="sr-only" x-text="deltaNetTax > 0 ? 'subiu' : 'desceu'"></span>
                    <span aria-hidden="true" x-text="(deltaNetTax > 0 ? '+' : '−') + ' € ' + fmt(Math.abs(deltaNetTax))"></span>
                  </span>
                </template>
              </span>
            </div>

            <template x-if="inflationAdjustedTakeHome !== null">
              <div class="detail-row inflation-row">
                <span class="lbl">
                  Poder de compra em <span x-text="availableYears[availableYears.length-1]"></span>€
                  <span class="badge" style="background:rgba(56,189,248,.15);color:var(--cyan);">inflação acum.</span>
                </span>
                <span class="val inflation-val" x-text="'≈ € ' + fmt(inflationAdjustedTakeHome)"></span>
              </div>
            </template>

          </div>

          <!-- TET -->
          <div class="tet-row">
            <span class="tet-label">Taxa Efetiva de Tributação</span>
            <div class="tet-val-wrap">
              <span class="tet-val" x-text="fmtPct(effectiveRate)"></span>
              <template x-if="deltaEffectiveRate !== null">
                <span :class="deltaClass(deltaEffectiveRate, true)">
                  <span class="sr-only" x-text="deltaEffectiveRate > 0 ? 'subiu' : 'desceu'"></span>
                  <span aria-hidden="true" x-text="(deltaEffectiveRate > 0 ? '+' : '') + deltaEffectiveRate.toFixed(2) + ' pp'"></span>
                </span>
              </template>
            </div>
          </div>

          <!-- A pagar / A receber -->
          <template x-if="withheld > 0">
            <div class="assessed-row" :class="assessedTax >= 0 ? 'payment' : 'refund'">
              <span class="assessed-label"
                    x-text="assessedTax >= 0 ? 'A pagar ao estado' : 'Reembolso estimado'">
              </span>
              <span class="assessed-val"
                    x-text="(assessedTax >= 0 ? '€ ' : '+ € ') + fmt(Math.abs(assessedTax))">
              </span>
            </div>
          </template>

        </div>
      </template>

      <!-- Escalões -->
      <button class="brackets-toggle" @click="showBrackets = !showBrackets"
              :aria-expanded="showBrackets"
              :aria-label="'Escalões de IRS ' + year + (showBrackets ? ' — fechar' : ' — abrir')">
        <span aria-hidden="true">Escalões <span x-text="year"></span></span>
        <span class="brackets-toggle-icon" aria-hidden="true" x-text="showBrackets ? '−' : '+'"></span>
      </button>

      <template x-if="showBrackets">
        <div class="brackets-section">
          <table>
            <caption class="sr-only" x-text="'Escalões de IRS ' + year"></caption>
            <thead>
              <tr>
                <th scope="col">Rendimento coletável</th>
                <th scope="col">Taxa</th>
                <th scope="col">Parcela a abater</th>
              </tr>
            </thead>
            <tbody>
              <template x-for="(row, idx) in bracketRows" :key="idx">
                <tr :class="row.active ? 'bracket-active' : ''">
                  <td>
                    <template x-if="row.to === null">
                      <span x-text="'Acima de € ' + fmtInt(row.from)"></span>
                    </template>
                    <template x-if="row.to !== null && row.from === 0">
                      <span x-text="'Até € ' + fmtInt(row.to)"></span>
                    </template>
                    <template x-if="row.to !== null && row.from > 0">
                      <span x-text="'€ ' + fmtInt(row.from) + ' – ' + fmtInt(row.to)"></span>
                    </template>
                  </td>
                  <td x-text="fmtPct(row.tax * 100)"></td>
                  <td x-text="row.parcel > 0 ? '€ ' + fmt(row.parcel) : '—'"></td>
                </tr>
              </template>
            </tbody>
          </table>
        </div>
      </template>

    </div><!-- /RIGHT -->

  </div><!-- /main-grid -->

  <footer class="footer">
    <span>Cálculo aproximado · Não substitui declaração oficial AT · Dados de 2008–2021 são aproximados.</span>
    <a class="footer-gh" href="https://github.com/hmiguel/irs" target="_blank" rel="noopener noreferrer" aria-label="Ver código no GitHub">
      <svg aria-hidden="true" focusable="false" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      hmiguel/irs
    </a>
  </footer>

</div><!-- /page -->

  <script is:inline set:html={`const TAX_DATA = ${JSON.stringify(taxData)};
const INFLATION = ${JSON.stringify(INFLATION_MAP)};`}></script>
  <script is:inline>
    function r2(n) { return Math.round(n * 100) / 100; }
    document.addEventListener('alpine:init', () => {
      Alpine.data('irsCalc', () => ({
        darkMode: localStorage.getItem('irs-theme') === 'dark',
        showBrackets: false,
        grossInput: '35000',
        municipality: 'porto',
        yearIdx: Math.min(Math.max(new Date().getFullYear() - 1, 2008), 2026) - 2008,
        specificDeductionInput: '',
        deductionsInput: '650',
        withheldInput: '5200',

        init() {
          this.$nextTick(() => {
            const m = this.municipality;
            this.municipality = '';
            this.$nextTick(() => { this.municipality = m; });
          });
        },

        get year()             { return this.availableYears[this.yearIdx]; },
        get yearSliderPercent(){ return (this.yearIdx / (this.availableYears.length - 1)) * 100; },
        get gross()      { return parseFloat(this.grossInput) || 0; },
        get deductions() { return parseFloat(this.deductionsInput) || 0; },
        get withheld()   { return parseFloat(this.withheldInput) || 0; },
        get yearData()   { return TAX_DATA[this.year]; },
        get countyRate() { return this.yearData.county_tax[this.municipality] ?? 0; },
        get brackets()   { return Object.values(this.yearData.table); },

        get availableYears() {
          return ['2008','2009','2010','2011','2012','2013','2014','2015',
                  '2016','2017','2018','2019','2020','2021','2022','2023','2024','2025','2026'];
        },
        get sliderPercent() { return Math.min(100, Math.max(0, this.gross / 1000)); },

        get sortedMunicipalities() {
          return Object.keys(this.yearData.county_tax).sort((a, b) => a.localeCompare(b, 'pt'));
        },
        get specificDeductionAuto() {
          return r2(Math.max(this.yearData.specific_deduction,
                             this.gross * this.yearData.social_security_tax));
        },
        get specificDeduction() {
          const m = parseFloat(this.specificDeductionInput);
          return isNaN(m) ? this.specificDeductionAuto : r2(m);
        },
        get collectableIncome() { return r2(Math.max(0, this.gross - this.specificDeduction)); },
        get bracket() {
          return this.brackets.find(b => this.collectableIncome < b.to)
              || this.brackets[this.brackets.length - 1];
        },
        get amountCalculated() { return r2(this.collectableIncome * this.bracket.tax); },
        get baseTax()          { return r2(this.amountCalculated - this.bracket.parcel); },
        get countyBenefit()    { return r2((this.baseTax - this.deductions) * (0.05 - this.countyRate)); },
        get netTax()           { return r2(this.baseTax - this.deductions - Math.max(0, this.countyBenefit)); },
        get takeHome()         { return r2(this.gross - this.specificDeduction - this.netTax); },
        get assessedTax()      { return r2(this.netTax - this.withheld); },
        get effectiveRate()    { return this.gross > 0 ? (this.netTax / this.gross * 100) : 0; },

        get prevYear() {
          const idx = this.availableYears.indexOf(this.year);
          return idx > 0 ? this.availableYears[idx - 1] : null;
        },
        get prevCalc() {
          if (!this.prevYear || this.gross === 0) return null;
          const yd = TAX_DATA[this.prevYear];
          const ss   = r2(Math.max(yd.specific_deduction, this.gross * yd.social_security_tax));
          const col  = r2(Math.max(0, this.gross - ss));
          const brks = Object.values(yd.table);
          const brk  = brks.find(b => col < b.to) || brks[brks.length - 1];
          const base = r2(col * brk.tax - brk.parcel);
          const cr   = yd.county_tax?.[this.municipality] ?? 0;
          const ben  = r2(base * (0.05 - cr));
          const net  = r2(base - Math.max(0, ben));
          return { netTax: net, takeHome: r2(this.gross - ss - net), tet: this.gross > 0 ? net / this.gross * 100 : 0 };
        },
        get bracketRows() {
          const brks = this.brackets;
          return brks.map((b, i) => {
            const from = i === 0 ? 0 : brks[i - 1].to;
            const to   = b.to >= 1e10 ? null : b.to;
            const active = this.gross > 0 &&
              this.collectableIncome > from &&
              (to === null || this.collectableIncome <= to);
            return { from, to, tax: b.tax, parcel: b.parcel, active };
          });
        },

        get deltaTakeHome()      { return this.prevCalc ? r2(this.takeHome      - this.prevCalc.takeHome) : null; },
        get deltaNetTax()        { return this.prevCalc ? r2(this.netTax        - this.prevCalc.netTax)   : null; },
        get deltaEffectiveRate() { return this.prevCalc ? r2(this.effectiveRate - this.prevCalc.tet)      : null; },

        get inflationAdjustedTakeHome() {
          if (this.gross === 0) return null;
          const latestYear = parseInt(this.availableYears[this.availableYears.length - 1]);
          const curYear = parseInt(this.year);
          if (curYear >= latestYear) return null;
          let factor = 1;
          for (let y = curYear + 1; y <= latestYear; y++) {
            factor *= (1 + (INFLATION[y] ?? 0) / 100);
          }
          return r2(this.takeHome * factor);
        },

        toggleTheme() {
          this.darkMode = !this.darkMode;
          localStorage.setItem('irs-theme', this.darkMode ? 'dark' : 'light');
        },

        deltaClass(n, inverse) {
          if (n === null || n === 0) return 'delta delta-neutral';
          if (inverse) return n > 0 ? 'delta delta-tax-up' : 'delta delta-tax-down';
          return n > 0 ? 'delta delta-up' : 'delta delta-down';
        },

        fmt(n) {
          return new Intl.NumberFormat('pt-PT', {minimumFractionDigits:2, maximumFractionDigits:2}).format(n);
        },
        fmtInt(n) {
          return new Intl.NumberFormat('pt-PT').format(Math.round(n));
        },
        fmtPct(n) {
          return new Intl.NumberFormat('pt-PT', {minimumFractionDigits:2, maximumFractionDigits:2}).format(n) + '%';
        },
        titleCase(s) {
          return s.replace(/(^|\s|\()(\S)/g, (_, sep, c) => sep + c.toUpperCase());
        },
      }));
    });
  </script>
</body>
