  <!-- Help modal -->
  <template x-teleport="body">
    <div class="help-overlay" x-show="showHelp" @click.self="showHelp = false" @keydown.escape.window="showHelp = false">
      <div class="help-modal" role="dialog" aria-modal="true" aria-label="Ajuda">
        <button class="help-close" @click="showHelp = false" aria-label="Fechar">
          <svg aria-hidden="true" focusable="false" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" d="M6 6l12 12M6 18L18 6"/>
          </svg>
        </button>

        <h2 class="help-title">Simulador IRS (Portugal)</h2>

        <div class="help-section">
          <div class="help-section-label">O que é</div>
          <p>Simulador interativo do IRS em Portugal para os anos fiscais de 2008 a 2026. Todos os cálculos são feitos no teu browser — nenhum dado é enviado para servidores.</p>
        </div>

        <div class="help-section">
          <div class="help-section-label">Como é calculado</div>
          <p>O simulador aplica a fórmula padrão do IRS para rendimentos de trabalho dependente (Categoria A):</p>
          <ol class="help-steps">
            <li>A <strong>dedução específica</strong> é subtraída ao rendimento bruto (máx. entre o mínimo legal e 11% do bruto — correspondente à Segurança Social)</li>
            <li>Se elegível ao <strong>IRS Jovem</strong>, uma percentagem do rendimento (até 55 × IAS) fica isenta</li>
            <li>O <strong>rendimento coletável</strong> é enquadrado no escalão correspondente, aplicando a taxa marginal e abatendo a parcela do escalão</li>
            <li>Ao resultado aplicam-se as <strong>deduções à coleta</strong> e o <strong>benefício municipal</strong> (diferença entre a taxa máxima de 5% e a taxa do município)</li>
          </ol>
        </div>

        <div class="help-section">
          <div class="help-section-label">IRS Jovem</div>
          <p>Regime de isenção parcial do IRS para jovens até 35 anos, aplicável a rendimentos das categorias A e B. Disponível a partir de 2025, com duração máxima de 10 anos:</p>
          <ul class="help-list">
            <li>1.º ano — 100% de isenção</li>
            <li>2.º ao 4.º ano — 75% de isenção</li>
            <li>5.º ao 7.º ano — 50% de isenção</li>
            <li>8.º ao 10.º ano — 25% de isenção</li>
          </ul>
          <p>A isenção aplica-se ao rendimento até ao limite de 55 × IAS (~€ 28 700 em 2025).</p>
        </div>

        <div class="help-section">
          <div class="help-section-label">Fontes de dados</div>
          <ul class="help-list">
            <li>Escalões e deduções: Código do IRS e Orçamentos do Estado</li>
            <li>Taxas municipais: deliberações das Assembleias Municipais, publicadas pela AT</li>
            <li>Inflação (IHPC): Banco de Portugal / INE</li>
          </ul>
        </div>

        <div class="help-section help-disclaimer">
          <div class="help-section-label">Limitações</div>
          <p>Este simulador é uma aproximação para rendimentos de <strong>Categoria A</strong> (trabalho dependente). Não contempla deduções por dependentes, saúde, educação ou habitação, sobretaxas extraordinárias, regimes autónomos regionais, nem regras para não residentes.</p>
          <p style="margin-top:.5rem;"><strong>Não substitui a declaração oficial AT nem aconselhamento fiscal qualificado.</strong></p>
          <p style="margin-top:.5rem;">Os dados fiscais foram compilados através de pesquisa independente e podem conter erros ou omissões. Verifica sempre os valores nas publicações oficiais da <strong>AT (Autoridade Tributária e Aduaneira)</strong> antes de tomar qualquer decisão financeira.</p>
        </div>
      </div>
    </div>
  </template>

</div><!-- /page -->

  <script is:inline set:html={`const TAX_DATA = ${JSON.stringify(taxData)};
const INFLATION = ${JSON.stringify(INFLATION_MAP)};`}></script>
  <script is:inline>
    function r2(n) { return Math.round(n * 100) / 100; }
    document.addEventListener('alpine:init', () => {
      Alpine.data('irsCalc', () => ({
        darkMode: localStorage.getItem('irs-theme') === 'dark',
        showBrackets: false,
        showHelp: false,
        grossInput: '35000',
        municipality: 'lisboa',
        yearIdx: Math.min(Math.max(new Date().getFullYear() - 1, 2008), 2026) - 2008,
        specificDeductionInput: '',
        deductionsInput: '650',
        withheldInput: '5200',
        irsJovemEnabled: false,
        irsJovemFirstYearInput: String(Math.min(Math.max(new Date().getFullYear() - 1, 2008), 2026) - 5),

        init() {
          try {
            const saved = JSON.parse(localStorage.getItem('irs-state') || 'null');
            if (saved) {
              const fields = ['grossInput','municipality','yearIdx','specificDeductionInput','deductionsInput','withheldInput','irsJovemEnabled','irsJovemFirstYearInput'];
              for (const f of fields) if (saved[f] !== undefined) this[f] = saved[f];
              this.yearIdx = Math.max(0, Math.min(this.availableYears.length - 1, this.yearIdx));
            }
          } catch {}
          ['grossInput','municipality','yearIdx','specificDeductionInput','deductionsInput','withheldInput','irsJovemEnabled','irsJovemFirstYearInput']
            .forEach(f => this.$watch(f, () => this._saveState()));
          this.$nextTick(() => {
            const m = this.municipality;
            this.municipality = '';
            this.$nextTick(() => { this.municipality = m; });
          });
        },

        get year()             { return this.availableYears[this.yearIdx]; },
        get yearSliderPercent(){ return (this.yearIdx / (this.availableYears.length - 1)) * 100; },
        get gross()      { return parseFloat(this.grossInput) || 0; },
        get deductions() { return parseFloat(this.deductionsInput) || 0; },
        get withheld()   { return parseFloat(this.withheldInput) || 0; },
        get yearData()   { return TAX_DATA[this.year]; },
        get countyRate() { return this.yearData.county_tax[this.municipality] ?? 0; },
        get brackets()   { return Object.values(this.yearData.table); },

        get availableYears() {
          return ['2008','2009','2010','2011','2012','2013','2014','2015',
                  '2016','2017','2018','2019','2020','2021','2022','2023','2024','2025','2026'];
        },
        get sliderPercent() { return Math.min(100, Math.max(0, this.gross / 1000)); },

        get sortedMunicipalities() {
          return Object.keys(this.yearData.county_tax).sort((a, b) => a.localeCompare(b, 'pt'));
        },
        get specificDeductionAuto() {
          return r2(Math.max(this.yearData.specific_deduction,
                             this.gross * this.yearData.social_security_tax));
        },
        get specificDeduction() {
          const m = parseFloat(this.specificDeductionInput);
          return isNaN(m) ? this.specificDeductionAuto : r2(m);
        },

        get irsJovemAvailable() { return parseInt(this.year) >= 2025; },
        get irsJovemActive()    { return this.irsJovemEnabled && this.irsJovemAvailable && this.irsJovemFirstYearValid; },
        get irsJovemFirstYear() { return parseInt(this.irsJovemFirstYearInput) || null; },
        get irsJovemFirstYearValid() {
          const fy = this.irsJovemFirstYear;
          const y  = parseInt(this.year);
          return fy !== null && fy >= y - 9 && fy <= y;
        },
        get irsJovemBenefitYear() {
          if (!this.irsJovemFirstYear) return null;
          return parseInt(this.year) - this.irsJovemFirstYear + 1;
        },
        get irsJovemRate() {
          const n = this.irsJovemBenefitYear;
          if (!n || n < 1 || n > 10) return 0;
          if (n === 1)          return 1.00;
          if (n <= 4)           return 0.75;
          if (n <= 7)           return 0.50;
          return 0.25;
        },
        get irsJovemCap()    { return 55 * (this.yearData.ias || 0); },
        get irsJovemExempt() {
          if (!this.irsJovemActive) return 0;
          return r2(Math.min(this.gross, this.irsJovemCap) * this.irsJovemRate);
        },

        get minimoExistencia() {
          const yd = this.yearData;
          return Math.max(yd.minimum_monthly_income * 14, 1.5 * 14 * yd.ias);
        },

        get collectableIncome() { return r2(Math.max(0, this.gross - this.specificDeduction - this.irsJovemExempt)); },
        get bracket() {
          return this.brackets.find(b => this.collectableIncome < b.to)
              || this.brackets[this.brackets.length - 1];
        },
        get amountCalculated() { return r2(this.collectableIncome * this.bracket.tax); },
        get baseTax()          { return r2(this.amountCalculated - this.bracket.parcel); },
        get solidarityTax() {
          const bands = this.yearData.solidarity?.bands;
          if (!bands || bands.length === 0) return 0;
          const income = this.collectableIncome;
          let tax = 0;
          for (let i = 0; i < bands.length; i++) {
            const from = bands[i].from;
            const to = i + 1 < bands.length ? bands[i + 1].from : Infinity;
            if (income <= from) break;
            tax += (Math.min(income, to) - from) * bands[i].rate;
          }
          return r2(tax);
        },
        get solidarityRateLabel() {
          const bands = this.yearData.solidarity?.bands;
          if (!bands || this.solidarityTax === 0) return '';
          const income = this.collectableIncome;
          return bands
            .filter(b => income > b.from)
            .map(b => (b.rate * 100).toLocaleString('pt-PT') + '%')
            .join(' + ');
        },
        get countyBenefit()    { return r2((this.baseTax - this.deductions) * (0.05 - this.countyRate)); },
        get rawNetTax()        { return r2(this.baseTax + this.solidarityTax - this.deductions - Math.max(0, this.countyBenefit)); },
        get minimoExistenciaActive() { return this.gross > 0 && this.rawNetTax > 0 && this.gross <= this.minimoExistencia; },
        get netTax()           { return Math.max(0, this.minimoExistenciaActive ? 0 : this.rawNetTax); },
        get takeHome()         { return r2(this.gross - this.specificDeduction - this.netTax); },
        get assessedTax()      { return r2(this.netTax - this.withheld); },
        get effectiveRate()    { return this.gross > 0 ? (this.netTax / this.gross * 100) : 0; },

        get prevYear() {
          const idx = this.availableYears.indexOf(this.year);
          return idx > 0 ? this.availableYears[idx - 1] : null;
        },
        get prevCalc() {
          if (!this.prevYear || this.gross === 0) return null;
          const yd = TAX_DATA[this.prevYear];
          const ss   = r2(Math.max(yd.specific_deduction, this.gross * yd.social_security_tax));
          const col  = r2(Math.max(0, this.gross - ss));
          const brks = Object.values(yd.table);
          const brk  = brks.find(b => col < b.to) || brks[brks.length - 1];
          const base = r2(col * brk.tax - brk.parcel);
          const cr   = yd.county_tax?.[this.municipality] ?? 0;
          const ben  = r2(base * (0.05 - cr));
          const net  = r2(base - Math.max(0, ben));
          return { netTax: net, takeHome: r2(this.gross - ss - net), tet: this.gross > 0 ? net / this.gross * 100 : 0 };
        },
        get bracketRows() {
          const brks = this.brackets;
          return brks.map((b, i) => {
            const from = i === 0 ? 0 : brks[i - 1].to;
            const to   = b.to >= 1e10 ? null : b.to;
            const active = this.gross > 0 &&
              this.collectableIncome > from &&
              (to === null || this.collectableIncome <= to);
            return { from, to, tax: b.tax, parcel: b.parcel, active };
          });
        },

        get deltaTakeHome()      { return this.prevCalc ? r2(this.takeHome      - this.prevCalc.takeHome) : null; },
        get deltaNetTax()        { return this.prevCalc ? r2(this.netTax        - this.prevCalc.netTax)   : null; },
        get deltaEffectiveRate() { return this.prevCalc ? r2(this.effectiveRate - this.prevCalc.tet)      : null; },

        get inflationAdjustedTakeHome() {
          if (this.gross === 0) return null;
          const latestYear = parseInt(this.availableYears[this.availableYears.length - 1]);
          const curYear = parseInt(this.year);
          if (curYear >= latestYear) return null;
          let factor = 1;
          for (let y = curYear + 1; y <= latestYear; y++) {
            factor *= (1 + (INFLATION[y] ?? 0) / 100);
          }
          return r2(this.takeHome * factor);
        },

        startIncomeDrag(e) {
          const sliderEl = document.getElementById('input-gross-slider');
          const rect = sliderEl.getBoundingClientRect();
          const update = (clientX) => {
            const pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
            this.grossInput = String(Math.round(pct * 100000 / 500) * 500);
          };
          update(e.clientX);
          e.target.style.cursor = 'pointer';
          const onMove = (ev) => update(ev.clientX);
          const onUp   = () => {
            e.target.style.cursor = '';
            window.removeEventListener('pointermove', onMove);
            window.removeEventListener('pointerup',   onUp);
          };
          window.addEventListener('pointermove', onMove);
          window.addEventListener('pointerup',   onUp);
        },

        _saveState() {
          localStorage.setItem('irs-state', JSON.stringify({
            grossInput: this.grossInput, municipality: this.municipality,
            yearIdx: this.yearIdx, specificDeductionInput: this.specificDeductionInput,
            deductionsInput: this.deductionsInput, withheldInput: this.withheldInput,
            irsJovemEnabled: this.irsJovemEnabled, irsJovemFirstYearInput: this.irsJovemFirstYearInput,
          }));
        },

        resetState() {
          localStorage.removeItem('irs-state');
          const y = Math.min(Math.max(new Date().getFullYear() - 1, 2008), 2026);
          this.grossInput = '35000'; this.municipality = 'lisboa';
          this.yearIdx = y - 2008; this.specificDeductionInput = '';
          this.deductionsInput = '650'; this.withheldInput = '5200';
          this.irsJovemEnabled = false; this.irsJovemFirstYearInput = String(y - 5);
        },

        toggleTheme() {
          this.darkMode = !this.darkMode;
          localStorage.setItem('irs-theme', this.darkMode ? 'dark' : 'light');
        },

        deltaClass(n, inverse) {
          if (n === null || n === 0) return 'delta delta-neutral';
          if (inverse) return n > 0 ? 'delta delta-tax-up' : 'delta delta-tax-down';
          return n > 0 ? 'delta delta-up' : 'delta delta-down';
        },

        fmt(n) {
          return new Intl.NumberFormat('pt-PT', {minimumFractionDigits:2, maximumFractionDigits:2}).format(n);
        },
        fmtInt(n) {
          return new Intl.NumberFormat('pt-PT').format(Math.round(n));
        },
        fmtPct(n) {
          return new Intl.NumberFormat('pt-PT', {minimumFractionDigits:2, maximumFractionDigits:2}).format(n) + '%';
        },
        titleCase(s) {
          return s.replace(/(^|\s|\()(\S)/g, (_, sep, c) => sep + c.toUpperCase());
        },
      }));
    });
  </script>

</body>
